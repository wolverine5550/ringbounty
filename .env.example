# Canonical public site URL for SEO (sitemap, metadata, canonical links)
# NEXT_PUBLIC_SITE_URL=https://ringbounty.com

# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SECRET_KEY=your-secret-key

# VITEST_SUPABASE_USER_ACCESS_TOKEN=

# Phase 5 — spam provider orchestration (optional; boolean strings: true / false / 1 / yes)
# SPAM_PROVIDER_NOMOROBO_ENABLED=false
# SPAM_PROVIDER_TWILIO_ENABLED=false

# Nomorobo Enterprise API (primary) — docs/Nomorobo Enterprise API Documentation.pdf
NOMOROBO_API_KEY=nomorobo-api-key
# Twilio Lookup v2 (secondary) — src/lib/spam/twilio-lookup-spam-provider.ts
TWILIO_ACCOUNT_SID=twilio-account-sid
TWILIO_AUTH_TOKEN=twilio-auth-token

# Phase 6 — federal DNC (§6.1 spike: automated lookup off until §6.2 vendor/API)
# FEDERAL_DNC_AUTOMATED_ENABLED=false
# Do NOT use FTC /v0/dnc-complaints for registry fields — see docs/spikes/20260516190000-federal-dnc-access.md
# FEDERAL_DNC_VENDOR_API_KEY=

# Phase 6.4.2 — FTC complaints company lookup (off; API cannot filter by caller phone)
# FTC_DNC_COMPLAINTS_COMPANY_LOOKUP_ENABLED=false
# API_DATA_GOV_KEY=

# Phase 6.4.2 — Whitepages Pro reverse phone (after Nomorobo/Twilio; trial: https://api.whitepages.com/docs/documentation/getting-started/getting-a-trial-api-key)
WHITEPAGES_COMPANY_LOOKUP_ENABLED=false
WHITEPAGES_API_KEY=whitepages-api-key

# Phase 6.5 / 7.5.1b — OpenCorporates company search + registered agent lookup
OPENCORPORATES_API_TOKEN=opencorporates-api-token

# Phase 7.5.4 — Voicemail transcription / extraction (OpenRouter)
OPENROUTER_API_KEY=openrouter-api-key

# Company Intelligence Agent (CI-0–CI-3; default off)
# When false/unset, agent is suggest-only: never sets company_identified (see docs/company-identification-strategy.md)
# COMPANY_INTEL_AUTO_PROMOTE_ENABLED=false
# When false/unset, SerpAPI + OpenRouter synthesis run only for signed-in check submits (anonymous may still enqueue free rounds)
# COMPANY_INTEL_ALLOW_ANONYMOUS_PAID_ROUNDS=false
# When false/unset, no Lane B enqueue on /check and cron drain no-ops (enable after CI-1.2 worker ships)
# COMPANY_INTELLIGENCE_AGENT_ENABLED=false

# Phase 13.1.4 — Attorney referral confirmation email (Resend HTTP API)
RESEND_API_KEY=resend-api-key
RESEND_FROM_EMAIL=RingBounty <onboarding@resend.dev>

# Phase 13.8.2 — Ops email when consumer reports firm contact issue (comma-separated)
OPS_DISPUTE_EMAIL=ops@example.com

# Phase 13.3 — Stripe Connect (firm lead billing, v0.2; optional until Stripe Dashboard is configured)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Phase 13.4.2 — Ops-only firm user invite (`POST /api/firms/invite`, Bearer token)
FIRM_OPS_INVITE_SECRET=firm-ops-invite-secret

# Phase 13.6.3 — Cron: firm lead status reminder (`POST /api/cron/firm-lead-status-reminder`, Bearer token)
CRON_SECRET=cron-secret

# Phase 13.7 — State DNC automated lookup (per-state; default off — see docs/spikes/20260517300000-state-dnc-integrations.md)
STATE_DNC_IN_ENABLED=false
STATE_DNC_TX_ENABLED=false
STATE_DNC_WY_ENABLED=false
STATE_DNC_CO_ENABLED=false
STATE_DNC_LA_ENABLED=false
STATE_DNC_MS_ENABLED=false
STATE_DNC_MO_ENABLED=false
STATE_DNC_OK_ENABLED=false
STATE_DNC_OR_ENABLED=false
STATE_DNC_PA_ENABLED=false
STATE_DNC_TN_ENABLED=false
